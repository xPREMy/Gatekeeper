# ═══════════════════════════════════════════════════════════════════════════
# Gatekeeper — Environment Variables
# Copy this to .env and customize as needed
# ═══════════════════════════════════════════════════════════════════════════

# --- App Settings ---
APP_NAME=Gatekeeper
APP_VERSION=1.0.0
DEBUG=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Rate Limiting Defaults ---
DEFAULT_RATE_LIMIT=100
DEFAULT_WINDOW_SECONDS=60

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
